# ── カイゼン窓口 環境変数（このファイルはコミットしてよい。値は入れない雛型）──
# 実際の値は .env.local（gitignore済み）または Vercel の Environment Variables に設定する。
# secrets/.env・本番デプロイは高木承認必須（ハイブリッドの本番前ゲート）。
#
# 各変数の「役割・既定・設定するとどうなるか」は README.md の「環境変数 一覧」を参照。
# 未設定でも窓口は動く（後方互換）。鍵が無い機能は安全に不活性化（fail-safe）。

# ── LLM（会話・要約）──
# Anthropic API（サーバ側ルートからのみ使用。クライアントには絶対出さない）
ANTHROPIC_API_KEY=
# 使用するClaudeモデル（任意。未設定なら claude-sonnet-4-6）
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 起票先（Notion 改善チケットDB）──
# Notion Internal Integration Token（改善チケットDBに「接続」を共有しておくこと）
NOTION_TOKEN=
# 起票先データソース（🔁 カイゼンくん 改善チケットDB）
NOTION_DATA_SOURCE_ID=3385ed10-660e-4917-ae90-a279afd71626
# 互換用（古いNotion APIで data source が使えない場合のフォールバック先 database_id）
NOTION_DATABASE_ID=4771cbc4-06d3-4eb9-a30f-05058ca69bd7

# ── 公開チャット(/api/chat) の濫用・コスト保護（任意・後方互換）──
# /api/chat は公開窓口で1ターンごとに課金API(Anthropic)を呼ぶ。プロセス内メモリのスライディング
# ウィンドウで IP単位の控えめな上限を課す第一防衛線。未設定なら下記の控えめな既定が効く。
# 注意：サーバレスはインスタンス毎メモリのため厳密ではない（best-effort）。
KAIZEN_CHAT_RATE_PER_MIN=20
KAIZEN_CHAT_RATE_PER_HOUR=100

# ── 公開起票API(/api/submit) のCSRF/オリジン制御（任意・後方互換）──
# 未設定なら全許可（後方互換・窓口を止めない）。設定する場合は「窓口自身」のオリジンを入れる。
# 重要：widget.js は窓口本体(kaizen.takagi.bz/?embed=1)を iframe で開くだけなので、起票POSTの
#   Origin は埋め込み先ホストではなく "常に窓口自身"＝kaizen.takagi.bz。埋め込み先ホストを書くと
#   実Origin(kaizen.takagi.bz)が許可されず全窓口が403になるので注意。複数はカンマ区切り。
#   例: KAIZEN_ALLOWED_ORIGINS=https://kaizen.takagi.bz
KAIZEN_ALLOWED_ORIGINS=

# ── 認証（任意・Auth.js v5 / Google OAuth）──
# 3つすべて揃った瞬間にログイン必須化（middlewareが保護）。1つでも欠けると認証OFF＝完全公開。
# 変数名は Auth.js v5 の規約名（コード側で参照しないが Auth.js が自動参照する）。
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# ログインを許可する会社ドメイン（任意・カンマ区切り）。未設定なら全Googleアカウント許可。
#   例: KAIZEN_ALLOWED_DOMAINS=takagi.bz
KAIZEN_ALLOWED_DOMAINS=

# ── 改善ループ・自動実行の保護（cron系内部API）──
# /api/process・/api/execute 等の内部API認証。未設定は本番fail-closed（401で不活性）。
CRON_SECRET=
# CRON_SECRET 未設定でも明示的に内部APIを通す逃がし弁（"1"のときのみ）。本番では使わない。
ALLOW_INSECURE_CRON=
# /api/line/push 専用の監視クライアント鍵（x-monitor-secret）。LINE通知のみ可の最小権限。
# kaizen-monitor（Slack監視→社長LINE報告）等のローカル常駐が使う。未設定なら CRON_SECRET のみ。
MONITOR_PUSH_SECRET=

# ── 自動改修（GitHub Actions ディスパッチ）──
# 設定すると「GO」で対象リポへ改修ジョブを発火（=自動改修ON）。未設定なら発火しない（提案で停止）。
GITHUB_DISPATCH_TOKEN=
# 改修ジョブを起こすオーケストレータ・リポ（既定 tkgathr2/kaizen-mado）。
KAIZEN_ORCHESTRATOR_REPO=tkgathr2/kaizen-mado
# 自動着手の可否（"off"/"false"/"0" で停止）。未設定＝デフォルトON（社長GO済の全自動運用）。
KAIZEN_AUTOPILOT=
# 「実装中」滞留をstuckとみなす分数（任意・既定30）。
KAIZEN_STUCK_MINUTES=
# ── Merge待ち一覧（毎朝6時JST・/api/cron/merge-wait-list）──
# tkgathr2 org横断でPR検索するための Personal Access Token（repo, read:org権限）。未設定ならno-op。
GITHUB_TOKEN=
# 投稿先の Slack Incoming Webhook URL。未設定ならno-op。
SLACK_WEBHOOK_URL=
# 窓口の公開ベースURL（callback/board リンク生成用。既定 https://kaizen.takagi.bz）。
KAIZEN_PUBLIC_BASE=

# ── LINE通知（提案→GO の窓口・任意）──
# 3つ揃うと提案をLINEへpush。未設定なら通知を送らない（不活性）。
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TARGET_USER_ID=

# ── ノウハウキング(knowhow) 連動（第1.5段・方向②デュアルライト）──
# 既定OFF。"true" で有効化すると、起票成功後に声を knowhow へ memorize する（PIIマスク後）。
KNOWHOW_ENABLED=false
KNOWHOW_API_BASE=https://knowhow.up.railway.app
KNOWHOW_PROJECT_KEY=cto-lab
# 将来 knowhow 認証がONになったら設定（無ければ送らない）
KB_API_KEY=
# 要約確認時に類似ノウハウを1回参照して一言添える（既定OFF）。"true" で有効。
KAIZEN_RECALL_ENABLED=false

# ── 学びの蒸留（distill・任意・第2段の学習ループ）──
# "true" で完了チケットからの学び蒸留を有効化。プロバイダは鍵の有無で自動選択。
KAIZEN_DISTILL_ENABLED=false
# 蒸留に使う各プロバイダのモデル（任意・未設定なら各既定）。
KAIZEN_DISTILL_MODEL=
KAIZEN_DISTILL_OPENAI_MODEL=
KAIZEN_DISTILL_GEMINI_MODEL=
# 蒸留・要約の代替LLM（どちらか設定があればフォールバックに使う）。
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
