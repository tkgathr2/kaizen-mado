# ── カイゼン窓口 環境変数（このファイルはコミットしてよい。値は入れない雛型）──
# 実際の値は .env.local（gitignore済み）または Vercel の Environment Variables に設定する。
# secrets/.env・本番デプロイは高木承認必須（ハイブリッドの本番前ゲート）。

# Anthropic API（サーバ側ルートからのみ使用。クライアントには絶対出さない）
ANTHROPIC_API_KEY=

# 使用するClaudeモデル（任意。未設定なら下記デフォルト）
ANTHROPIC_MODEL=claude-sonnet-4-6

# Notion Internal Integration Token（改善チケットDBに「接続」を共有しておくこと）
NOTION_TOKEN=

# 起票先データソース（🔁 カイゼンくん 改善チケットDB）
NOTION_DATA_SOURCE_ID=3385ed10-660e-4917-ae90-a279afd71626
# 互換用（古いNotion APIで data source が使えない場合のフォールバック先 database_id）
NOTION_DATABASE_ID=4771cbc4-06d3-4eb9-a30f-05058ca69bd7

# ── 公開起票API(/api/submit) のCSRF/オリジン制御（任意・後方互換）──
# 未設定なら全許可（後方互換・窓口を止めない）。設定する場合は「窓口自身」のオリジンを入れる。
# 重要：widget.js は窓口本体(kaizen.takagi.bz/?embed=1)を iframe で開くだけなので、起票POSTの
#   Origin は埋め込み先ホストではなく "常に窓口自身"＝kaizen.takagi.bz。埋め込み先ホストを書くと
#   実Origin(kaizen.takagi.bz)が許可されず全窓口が403になるので注意。複数はカンマ区切り。
#   例: KAIZEN_ALLOWED_ORIGINS=https://kaizen.takagi.bz
KAIZEN_ALLOWED_ORIGINS=

# ── ノウハウキング(knowhow) 連動（第1.5段・方向②デュアルライト）──
# 既定OFF。"true" で有効化すると、起票成功後に声を knowhow へ memorize する（PIIマスク後）。
KNOWHOW_ENABLED=false
KNOWHOW_API_BASE=https://knowhow.up.railway.app
KNOWHOW_PROJECT_KEY=cto-lab
# 将来 knowhow 認証がONになったら設定（無ければ送らない）
KB_API_KEY=
